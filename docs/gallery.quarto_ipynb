   "source": [
    "## Automaton\n",
    "\n",
    "This example uses a force layout to draw a simple graph that represents an automaton."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "5f95aa5c",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/svg+xml": [
       "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"280.0\" height=\"120.0\" viewBox=\"-50.0 -60.0 280.0 120.0\">\n",
