       "<g transform=\"translate(0.0 79.0) rotate(0.0) scale(1.0 1.0)\">\n",
       "<rect x=\"-50.0\" y=\"-15.0\" width=\"100\" height=\"30\" stroke=\"black\" fill=\"rgba(0,0,0,0.0)\"/>\n",
       "</g>\n",
       "<g transform=\"translate(0.0 111.0) rotate(0.0) scale(1.0 1.0)\">\n",
       "<rect x=\"-50.0\" y=\"-15.0\" width=\"100\" height=\"30\" stroke=\"black\" fill=\"rgba(0,0,0,0.0)\"/>\n",
       "</g>\n",
       "  <path d=\"M -90.0 15.0 L -55.0 15.0\" fill=\"rgba(0,0,0,0.0)\" stroke=\"rgba(0,0,0,1.0)\" stroke-width=\"1.0\" marker-end=\"url(#arrow)\"/>\n",
