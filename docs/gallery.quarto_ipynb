       "  <path d=\"M 220.0 60.0 L 220.0 25.0\" fill=\"rgba(0,0,0,0.0)\" stroke=\"rgba(0,0,0,1.0)\" stroke-width=\"1.0\" marker-end=\"url(#arrow)\"/>\n",
       "  <path d=\"M 320.0 -50.0 L 300.0 -25.0\" fill=\"rgba(0,0,0,0.0)\" stroke=\"rgba(0,0,0,1.0)\" stroke-width=\"1.0\" marker-end=\"url(#arrow)\"/>\n",
