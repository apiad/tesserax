       "  <g transform=\"translate(20.0 0.0) rotate(0.0) scale(1.0 1.0)\">\n",
       "<circle cx=\"0\" cy=\"0\" r=\"20\" stroke=\"rgba(0,0,0,1.0)\" fill=\"rgba(0,0,0,0.0)\"/>\n",
       "</g>\n",
       "<g transform=\"translate(110.0 -30.0) rotate(0.0) scale(1.0 1.0)\">\n",
       "<circle cx=\"0\" cy=\"0\" r=\"20\" stroke=\"rgba(0,0,0,1.0)\" fill=\"rgba(0,0,0,0.0)\"/>\n",
       "</g>\n",
       "<g transform=\"translate(110.0 30.0) rotate(0.0) scale(1.0 1.0)\">\n",
       "<circle cx=\"0\" cy=\"0\" r=\"20\" stroke=\"rgba(0,0,0,1.0)\" fill=\"rgba(0,0,0,0.0)\"/>\n",
       "</g>\n",
       "<g transform=\"translate(200.0 0.0) rotate(0.0) scale(1.0 1.0)\">\n",
       "<circle cx=\"0\" cy=\"0\" r=\"20\" stroke=\"rgba(0,0,0,1.0)\" fill=\"rgba(0,0,0,0.0)\"/>\n",
       "</g>\n",
       "  <path d=\"M 38.973665961010276 -6.324555320336759 L 91.02633403898972 -23.67544467966324\" fill=\"rgba(0,0,0,0.0)\" stroke=\"rgba(0,0,0,1.0)\" stroke-width=\"1.0\" marker-end=\"url(#arrow)\"/>\n",
       "  <path d=\"M 110.0 -10.0 L 110.0 10.0\" fill=\"rgba(0,0,0,0.0)\" stroke=\"rgba(0,0,0,1.0)\" stroke-width=\"1.0\" marker-end=\"url(#arrow)\"/>\n",
       "  <path d=\"M 91.02633403898972 23.67544467966324 L 38.973665961010276 6.324555320336759\" fill=\"rgba(0,0,0,0.0)\" stroke=\"rgba(0,0,0,1.0)\" stroke-width=\"1.0\" marker-end=\"url(#arrow)\"/>\n",
       "  <path d=\"M 128.97366596101028 23.67544467966324 L 181.02633403898972 6.324555320336759\" fill=\"rgba(0,0,0,0.0)\" stroke=\"rgba(0,0,0,1.0)\" stroke-width=\"1.0\" marker-end=\"url(#arrow)\"/>\n",
       "  <path d=\"M -40.0 0.0 L 0.0 0.0\" fill=\"rgba(0,0,0,0.0)\" stroke=\"rgba(0,0,0,1.0)\" stroke-width=\"1.0\" marker-end=\"url(#arrow)\"/>\n",
